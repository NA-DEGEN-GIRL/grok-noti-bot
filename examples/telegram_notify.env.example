# Copy to ~/.grok/telegram_notify.env and fill in locally.
# Never commit the real file.

AI_WORKLOG_BOT_TOKEN=<YOUR_TELEGRAM_BOT_TOKEN>
AI_WORKLOG_CHAT_ID=<YOUR_FORUM_SUPERGROUP_CHAT_ID>
AI_WORKLOG_AUTO_CREATE_TOPICS=true
AI_WORKLOG_ENABLED=true

# Optional: verify hook execution without sending a Telegram message.
# AI_WORKLOG_DRY_RUN=true
# LLM_NOTI_DRY_RUN=1

# Optional display controls. Telegram stays compact by default.
# AI_WORKLOG_SHOW_AGENT=true
# AI_WORKLOG_SHOW_GIT=false
# AI_WORKLOG_SHOW_FILES=false

# Optional: force all worklogs into one known Telegram topic.
# AI_WORKLOG_TOPIC_ID=<MESSAGE_THREAD_ID>
